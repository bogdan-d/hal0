# hal0 dashboard dev-server env overrides (Vite). Copy to .env to use.

# Comma-separated hostnames the Vite dev server will accept (Host header
# allowlist). Defaults to localhost. Set this to expose `npm run dev`
# behind a reverse proxy on custom hostnames.
# VITE_ALLOWED_HOSTS=host1,host2

# Hostname for HMR over WSS when serving the dev server through a
# TLS-terminating reverse proxy. Leave unset for plain local dev.
# VITE_HMR_HOST=host1
