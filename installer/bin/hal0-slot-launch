#!/usr/bin/env bash
# hal0-slot-launch — slot container launcher
#
# Called by hal0-slot@<name>.service as:
#   ExecStart=/usr/lib/hal0/current/bin/hal0-slot-launch <slot-name>
#
# Phase 0: stub. Prints a TODO and exits 0 so systemd considers the
# unit "started" without error. Phase 1 will replace this body with
# real docker run logic derived from the slot's TOML + env file.
#
# Phase 1 contract (for the implementor):
#   1. Read /etc/hal0/slots/${SLOT}.toml        — backend, model, port
#   2. Read /var/lib/hal0/slots/${SLOT}/env     — runtime overrides
#   3. Resolve toolbox image from hal0's manifest.json for the backend
#   4. exec docker run with:
#      --name hal0-slot-${SLOT}
#      --rm
#      --network host  (or a named bridge; TBD in Phase 1)
#      --device /dev/dri/... (GPU passthrough per hardware.json)
#      -v /var/lib/hal0/models:/models:ro
#      -v /var/lib/hal0/slots/${SLOT}:/slot-state
#      --env-file /var/lib/hal0/slots/${SLOT}/env
#      ghcr.io/hal0-dev/hal0-toolbox-<backend>:<tag>
#      <backend-specific args from TOML>

set -euo pipefail
IFS=$'\n\t'

SLOT="${1:-}"

if [[ -z "${SLOT}" ]]; then
    echo "hal0-slot-launch: ERROR: slot name argument is required" >&2
    echo "Usage: hal0-slot-launch <slot-name>" >&2
    exit 1
fi

# Phase 0 stub — replace this block in Phase 1
echo "TODO Phase 1: launch slot ${SLOT} per /etc/hal0/slots/${SLOT}.toml"
exit 0
