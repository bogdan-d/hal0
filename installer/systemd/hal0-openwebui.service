[Unit]
Description=hal0 OpenWebUI companion (ghcr.io/open-webui/open-webui)
Documentation=https://github.com/open-webui/open-webui
# Docker must be up before we try to run a container.
After=docker.service
Requires=docker.service
# The API must be reachable so OpenWebUI's OPENAI_API_BASE_URLS health
# check on first boot finds a live endpoint. 'Wants' (not 'Requires')
# so OpenWebUI can still start if hal0-api is temporarily down.
After=hal0-api.service
Wants=hal0-api.service

[Service]
Type=simple

# /etc/hal0/openwebui.env is written by install.sh.
# Key vars: OPENAI_API_BASE_URLS, WEBUI_AUTH, WEBUI_NAME, DATA_DIR.
# Managed by 'hal0 config' subcommands — do not edit while the unit is
# running without a subsequent 'systemctl restart hal0-openwebui'.
EnvironmentFile=/etc/hal0/openwebui.env

# --rm so the container is cleaned up on any exit (normal or crash).
# The container name is stable so ExecStop can target it by name.
# Data is kept in /var/lib/hal0/openwebui/ which survives container
# restarts and hal0 updates.
ExecStart=/usr/bin/docker run \
  --rm \
  --name hal0-openwebui \
  --env-file /etc/hal0/openwebui.env \
  -v /var/lib/hal0/openwebui:/app/backend/data \
  -p 3001:8080 \
  ghcr.io/open-webui/open-webui:main

# Graceful stop: tell the named container to stop (SIGTERM + 10s timeout
# is docker's default). systemd will SIGKILL ExecStart if it doesn't
# exit within TimeoutStopSec.
ExecStop=/usr/bin/docker stop hal0-openwebui

# If Docker exits with 0 (user ran 'docker stop' manually) we still want
# the unit to restart, so use always rather than on-failure.
Restart=on-failure
RestartSec=5

StandardOutput=journal+console
StandardError=journal+console
SyslogIdentifier=hal0-openwebui

[Install]
WantedBy=multi-user.target
