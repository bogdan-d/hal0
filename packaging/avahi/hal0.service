<?xml version="1.0" standalone='no'?>
<!--
  hal0 mDNS service announcement.

  Dropped at /etc/avahi/services/hal0.service by `installer/install.sh
  --auth=basic` when avahi-daemon is present on the host. Lets clients on
  the same broadcast domain resolve `hal0.local` (or whatever HAL0_HOSTNAME
  was at install time) without a DNS entry — pair with the Caddy
  `tls internal` block in /etc/hal0/Caddyfile so HTTPS works out of the box.

  When avahi isn't installed (or .local resolution is intentionally off,
  e.g. on a managed corporate network), users can fall back to a static
  /etc/hosts entry instead:

      <hal0-host-ip>   hal0.local

  Skip silently if avahi-daemon isn't present — this is a convenience,
  not a hard requirement.
-->
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<service-group>
  <name replace-wildcards="yes">hal0 on %h</name>

  <!--
    Caddy serves HTTPS on :443 and redirects HTTP→HTTPS on :80. We
    advertise both so clients that only know about plain http (a few
    legacy probes) still discover us; Caddy bounces them up to HTTPS.
  -->
  <service>
    <type>_https._tcp</type>
    <port>443</port>
    <txt-record>path=/</txt-record>
    <txt-record>name=hal0</txt-record>
  </service>

  <service>
    <type>_http._tcp</type>
    <port>80</port>
    <txt-record>path=/</txt-record>
    <txt-record>name=hal0</txt-record>
  </service>
</service-group>
